# GuildBanker — .gitignore
# Go API + React (TypeScript) Monorepo
# ============================================================

# ============================================================
# Go (api/)
# ============================================================
api/bin/
api/dist/
api/*.exe
api/*.exe~
api/*.dll
api/*.so
api/*.dylib
api/*.test
api/*.out
api/vendor/
api/coverage.out
api/coverage.html

# Air (live reload)
api/tmp/
api/.air.toml.bak

# Go workspace
go.work.sum

# ============================================================
# React / Node (web/)
# ============================================================
web/node_modules/
web/dist/
web/build/
web/.next/
web/out/
web/.cache/
web/.parcel-cache/
web/coverage/
web/*.local

# Vite
web/.vite/

# ============================================================
# Environment & Secrets
# ============================================================
.env
.env.*
!.env.example
**/.env
**/.env.*
!**/.env.example

# ============================================================
# Docker
# ============================================================
infra/postgres/data/
infra/keycloak/data/

# ============================================================
# IDEs & Editors
# ============================================================

# VSCode
.vscode/
!.vscode/extensions.json
!.vscode/settings.json.example

# JetBrains (GoLand, WebStorm)
.idea/
*.iml
*.iws
*.ipr

# Vim / Neovim
*.swp
*.swo
*~
.netrwhist

# Emacs
*#
.#*

# ============================================================
# OS
# ============================================================

# macOS
.DS_Store
.AppleDouble
.LSOverride
._*
.Spotlight-V100
.Trashes

# Windows
Thumbs.db
Thumbs.db:encryptable
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

# Linux
*~

# ============================================================
# Logs & Temp
# ============================================================
*.log
*.tmp
*.temp
logs/
tmp/

# ============================================================
# Test & Coverage
# ============================================================
coverage/
*.cover
*.coverprofile
test-results/
junit.xml

# ============================================================
# Build Artifacts
# ============================================================
*.tar.gz
*.zip
dist/
build/

# ============================================================
# Uploads & Generated Files (runtime)
# ============================================================
uploads/
exports/
